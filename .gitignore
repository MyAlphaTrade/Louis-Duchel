# Python embeddable (téléchargé en CI, pas commité)
**/python/python-win/

# Paquets Python installés localement via pip --target (réinstallés en CI)
# Seuls alphatrade_engine.py et alphatrade_ai_server.py doivent être commités
**/python/*/
**/python/*.pyd
