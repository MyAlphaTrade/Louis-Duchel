{
  "name": "alphatrade",
  "version": "4.0.1",
  "description": "AlphaTrade v4.0.1 - Trading IA MetaTrader 5",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.myalphatrade.app",
    "productName": "AlphaTrade",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "../dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.ico",
      "category": "public.app-category.finance"
    },
    "dmg": {
      "title": "AlphaTrade"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AlphaTrade"
    },
    "publish": {
      "provider": "github",
      "owner": "myalphatrade",
      "repo": "alphatrade-releases",
      "private": false
    },
    "extraResources": [
      {
        "from": "../python/",
        "to": "python/",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyi",
          "!**/tests/**",
          "!**/test_*.py",
          "!**/*.dist-info/**",
          "!**/*.whl"
        ]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "assets/**/*",
      "i18n/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
